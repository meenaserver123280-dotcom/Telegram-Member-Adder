# channel.py - Telegram Group Mein Members Add Karne Ka Script
# Telethon Library Use Karta Hai

import asyncio
import sys
from telethon import TelegramClient
from telethon.tl.functions.channels import InviteToChannelRequest
from telethon.tl.functions.messages import AddChatUserRequest
from telethon.errors import UserPrivacyRestrictedError, FloodWaitError, UserNotMutualContactError
import time

# ===== YAHAN APNI VALUES DALEN =====
API_ID = 1234567          # Apna API ID (my.telegram.org se lo)
API_HASH = "abcd1234xyz"  # Apna API Hash
PHONE_NUMBER = "+911234567890"  # Apna Telegram number
GROUP_USERNAME = "@aapkagroupusername"  # Jis group mein add karna hai uska username
# ===================================

# members.py se list import karo
from members import members_list

async def main():
    # Client banayein
    client = TelegramClient('session_name', API_ID, API_HASH)
    await client.start(phone=PHONE_NUMBER)
    print("✅ Login successful!")

    # Group resolve karein
    try:
        group = await client.get_entity(GROUP_USERNAME)
        print(f"✅ Group found: {group.title} (ID: {group.id})")
    except Exception as e:
        print(f"❌ Group not found: {e}")
        return

    added_count = 0
    failed_count = 0

    print(f"\n🚀 Adding {len(members_list)} members to {GROUP_USERNAME}...")
    print("⚠️ Telegram sirf ~50 members per account add karne deta hai.\n")

    for i, member in enumerate(members_list, 1):
        username = member["username"]
        name = member["name"]

        try:
            # User ko resolve karein
            try:
                user = await client.get_entity(username)
            except Exception:
                print(f"[{i}] ❌ {username} ({name}) - User not found on Telegram")
                failed_count += 1
                continue

            # Group mein add karein (supergroup/channel ke liye)
            try:
                await client(InviteToChannelRequest(
                    group,
                    [user]
                ))
                print(f"[{i}] ✅ Added: {username} ({name})")
                added_count += 1
            except UserPrivacyRestrictedError:
                print(f"[{i}] ⚠️ Privacy restricted: {username} ({name})")
                failed_count += 1
            except FloodWaitError as e:
                wait_time = e.seconds
                print(f"⏳ Flood wait: {wait_time} seconds. Rukna padega...")
                time.sleep(wait_time)
                # Retry
                try:
                    await client(InviteToChannelRequest(group, [user]))
                    print(f"[{i}] ✅ Added after wait: {username} ({name})")
                    added_count += 1
                except Exception as e2:
                    print(f"[{i}] ❌ Failed after wait: {username} - {e2}")
                    failed_count += 1
            except Exception as e:
                print(f"[{i}] ❌ Failed: {username} ({name}) - {e}")
                failed_count += 1

        except KeyboardInterrupt:
            print("\n⛔ User ne interrupt kiya. Script band.")
            break

        # Har 5 members ke baad 2 second ka delay (ban na ho)
        if i % 5 == 0:
            time.sleep(2)

    print("\n" + "=" * 40)
    print("📊 FINAL REPORT")
    print(f"✅ Successfully added: {added_count}")
    print(f"❌ Failed: {failed_count}")
    print(f"📝 Total attempted: {added_count + failed_count}")
    print("=" * 40)

    await client.disconnect()

if __name__ == "__main__":
    asyncio.run(main())
